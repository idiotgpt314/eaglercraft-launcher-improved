{
  "name": "eaglercraft-launcher-improved",
  "version": "1.0.0",
  "description": "A packaged desktop launcher for local Eaglercraft builds.",
  "main": "main.js",
  "author": {
    "name": "Lil Archyfour",
    "email": "jaydencrowther@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist:linux": "electron-builder --linux AppImage deb pacman",
    "dist:win": "electron-builder --win nsis portable",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist": "electron-builder --linux AppImage deb pacman --win nsis portable"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.idiotgpt314.eaglercraftlauncher",
    "productName": "Eaglercraft Launcher Improved",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "*.html",
      "build/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "mac": {
      "category": "public.app-category.games",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "category": "Game",
      "maintainer": "Lil Archyfour <jaydencrowther@gmail.com>",
      "target": [
        "AppImage",
        "deb",
        "pacman"
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    }
  }
}
